{
  "name": "@svg-solid-plugin/rspack",
  "version": "0.0.0",
  "description": "Universal plugin for transforming SVG files into SolidJS components. Works with both Rspack and Webpack.",
  "author": "solarlime",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "homepage": "https://github.com/solarlime/svg-solid-plugin/tree/main/packages/rspack",
  "bugs": {
    "url": "https://github.com/solarlime/svg-solid-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solarlime/svg-solid-plugin.git",
    "directory": "packages/rspack"
  },
  "keywords": [
    "svg",
    "solid",
    "solidjs",
    "rspack",
    "webpack",
    "plugin",
    "loader",
    "jsx",
    "component",
    "svgo"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "tsdown --clean",
    "type-check": "tscw",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "dependencies": {
    "svgo": "^4.0.1"
  },
  "devDependencies": {
    "@rspack/core": "^1.7.10",
    "tscw-config": "^1.1.2",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4"
  },
  "peerDependencies": {
    "@rspack/core": "^1",
    "babel-loader": "^10",
    "babel-preset-solid": "^1",
    "solid-js": "^1",
    "webpack": "^5"
  },
  "peerDependenciesMeta": {
    "webpack": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
